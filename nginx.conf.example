server {
    listen 80;
    listen [::]:80;
    server_name systemmedia.de www.systemmedia.de bim.systemmedia.de ifc.systemmedia.de automation.systemmedia.de projects.systemmedia.de;

    root /opt/systemmedia-website/dist;
    index index.html;

    gzip on;
    gzip_types text/plain text/css application/json application/javascript image/svg+xml;

    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "DENY" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=(), fullscreen=(self)" always;

    location / {
        try_files $uri $uri/ /index.html;
    }

    location ~* \.(js|css|svg|jpg|jpeg|png|webp|woff2?)$ {
        expires 30d;
        add_header Cache-Control "public, immutable";
        try_files $uri =404;
    }
}
