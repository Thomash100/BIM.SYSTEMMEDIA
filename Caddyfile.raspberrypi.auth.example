(systemmedia_headers) {
  header {
    X-Content-Type-Options "nosniff"
    X-Frame-Options "DENY"
    Referrer-Policy "strict-origin-when-cross-origin"
    Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=(), fullscreen=(self)"
  }
  encode gzip zstd
}

(systemmedia_auth) {
  basic_auth {
    admin __SYSTEMMEDIA_ADMIN_HASH__
  }
}

www.systemmedia.de {
  redir https://systemmedia.de{uri} permanent
}

systemmedia.de {
  import systemmedia_headers
  import systemmedia_auth
  root * /opt/systemmedia-website/dist
  try_files {path} /index.html
  file_server
}

bim.systemmedia.de {
  import systemmedia_headers
